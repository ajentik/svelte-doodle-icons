{
  "name": "doo-iconik",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "generate": "node generate.mjs",
    "build": "npm run generate && npm run build --workspaces",
    "build:core": "npm run build --workspace=packages/core",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  }
}
