{
  "name": "@doo-iconik/vue",
  "version": "1.0.0",
  "description": "Vue 3 component adapter for doo-iconik icons",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "dependencies": {
    "@doo-iconik/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vue": "^3.3.0"
  },
  "keywords": ["icons", "doodle", "hand-drawn", "vue", "vue3", "ui", "doo-iconik"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajentik/doo-iconik.git",
    "directory": "packages/vue"
  }
}
