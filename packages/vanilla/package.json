{
  "name": "@doo-iconik/vanilla",
  "version": "1.0.0",
  "description": "Vanilla JavaScript adapter (Web Component + createIcon) for doo-iconik icons",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs,iife --global-name DooIconik --dts"
  },
  "dependencies": {
    "@doo-iconik/core": "file:../core"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["icons", "doodle", "hand-drawn", "web-components", "custom-elements", "vanilla", "ui", "doo-iconik"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajentik/doo-iconik.git",
    "directory": "packages/vanilla"
  }
}
